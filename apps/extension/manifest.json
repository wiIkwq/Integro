{
  "manifest_version": 3,
  "name": "Integro YouTube Overlay",
  "description": "Integro commands panel for the @bebrok YouTube live stream.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Integro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://integro.bohdan.lol/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/minecraft.ttf"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ]
    }
  ],
  "permissions": [
    "cookies",
    "storage",
    "tabs"
  ]
}
