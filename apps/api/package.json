{
  "name": "@integro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "check": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create integro-db",
    "db:apply:local": "wrangler d1 migrations apply integro-db --local",
    "db:apply:remote": "wrangler d1 migrations apply integro-db --remote"
  },
  "dependencies": {
    "hono": "^4.11.2"
  },
  "devDependencies": {
    "wrangler": "^4.90.1"
  }
}
